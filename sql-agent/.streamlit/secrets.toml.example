# Streamlit Community Cloud secrets template.
#
# DO NOT commit a real secrets.toml — it is gitignored. Instead paste these
# keys (with real values) into your app on Streamlit Cloud under:
#   App  →  Settings  →  Secrets
# Streamlit exposes them to the app as environment variables, so the existing
# os.getenv(...) calls pick them up with no code change.

OPENAI_API_KEY = "sk-..."
OPENAI_MODEL = "gpt-4o"
OPENAI_TEMPERATURE = "0"

# Arize AX tracing (optional — set ARIZE_TRACING_ENABLED = "false" to skip).
ARIZE_TRACING_ENABLED = "true"
ARIZE_SPACE_ID = "your-space-id"
ARIZE_API_KEY = "your-arize-api-key"
ARIZE_PROJECT_NAME = "sql-analytics-agent"
