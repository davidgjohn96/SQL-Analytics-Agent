# ---------------------------------------------------------------------------
# LLM (OpenAI-compatible endpoint)
#
# The agent talks to any OpenAI-compatible API. By default it uses Groq to
# serve OpenAI's open-weight gpt-oss-120b model. To use a different provider or
# model, change OPENAI_BASE_URL + OPENAI_MODEL and supply that provider's key.
# Leave OPENAI_BASE_URL blank to use OpenAI itself.
# ---------------------------------------------------------------------------

# Provider endpoint. Groq: https://api.groq.com/openai/v1
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# The provider's API key (a Groq key when using the default base URL above).
# Get one at https://console.groq.com/keys
OPENAI_API_KEY=your-groq-api-key-here

# Open-source model id. Groq examples: openai/gpt-oss-120b, llama-3.3-70b-versatile
OPENAI_MODEL=openai/gpt-oss-120b

# Temperature for SQL generation (low = more deterministic).
OPENAI_TEMPERATURE=0

# ---------------------------------------------------------------------------
# Arize AX (cloud observability)
# Get these from https://app.arize.com  ->  Settings / Space Settings
# ---------------------------------------------------------------------------
ARIZE_SPACE_ID=your-arize-space-id
ARIZE_API_KEY=your-arize-api-key
ARIZE_PROJECT_NAME=sql-analytics-agent

# Set to "false" to disable tracing entirely (e.g. offline dev).
ARIZE_TRACING_ENABLED=true
