# ---------------------------------------------------------------------------
# OpenAI
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model is fully configurable. The spec calls for "GPT-5.5"; set whatever
# model id your account has access to. Defaults to a real, current model.
OPENAI_MODEL=gpt-4o

# Temperature for SQL generation (low = more deterministic).
OPENAI_TEMPERATURE=0

# ---------------------------------------------------------------------------
# Arize AX (cloud observability)
# Get these from https://app.arize.com  ->  Settings / Space Settings
# ---------------------------------------------------------------------------
ARIZE_SPACE_ID=your-arize-space-id
ARIZE_API_KEY=your-arize-api-key
ARIZE_PROJECT_NAME=sql-analytics-agent

# Set to "false" to disable tracing entirely (e.g. offline dev).
ARIZE_TRACING_ENABLED=true
